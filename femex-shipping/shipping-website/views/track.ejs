<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Track Shipment - ChicagoShip</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <!-- Same navbar as index -->
        <div class="container">
            <a class="navbar-brand" href="/">ChicagoShip</a>
            <!-- nav links -->
        </div>
    </nav>
    <div class="container mt-5">
        <h2>Shipment Tracking</h2>
        <% if (shipment) { %>
            <div class="card">
                <div class="card-body">
                    <h4>Tracking ID: <%= shipment.id %></h4>
                    <p>Status: <%= shipment.status %></p>
                    <p>Location: <%= shipment.location %></p>
                    <!-- Progress bar for tracking -->
                    <div class="progress">
                        <div class="progress-bar" style="width: <%= shipment.progress %>%"></div>
                    </div>
                </div>
            </div>
        <% } else { %>
            <p>No shipment found or enter ID to track.</p>
        <% } %>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
