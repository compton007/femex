<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Book Shipment - ChicagoShip</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/">ChicagoShip</a>
        </div>
    </nav>
    <div class="container mt-5">
        <h2>Book a Shipment</h2>
        <form action="/book" method="POST">
            <div class="mb-3">
                <label>Sender Address</label>
                <input type="text" class="form-control" name="sender" required>
            </div>
            <div class="mb-3">
                <label>Receiver Address</label>
                <input type="text" class="form-control" name="receiver" required>
            </div>
            <div class="mb-3">
                <label>Package Weight (kg)</label>
                <input type="number" class="form-control" name="weight" required>
            </div>
            <button type="submit" class="btn btn-primary">Book Shipment</button>
        </form>
    </div>
</body>
</html>
