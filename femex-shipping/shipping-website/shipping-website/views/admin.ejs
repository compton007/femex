<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Panel - ChicagoShip</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <div class="container mt-5">
        <h2>Admin Control Panel</h2>
        <h4>All Shipments Management</h4>
        <table class="table">
            <thead><tr><th>ID</th><th>Status</th><th>Progress</th><th>Actions</th></tr></thead>
            <tbody>
                <% shipments.forEach(s => { %>
                    <tr>
                        <td><%= s.id %></td>
                        <td><%= s.status %></td>
                        <td><%= s.progress %>%</td>
                        <td>
                            <form action="/admin/update" method="POST" style="display:inline;">
                                <input type="hidden" name="id" value="<%= s.id %>">
                                <select name="status">
                                    <option value="Booked">Booked</option>
                                    <option value="In Transit">In Transit</option>
                                    <option value="Delivered">Delivered</option>
                                </select>
                                <input type="number" name="progress" value="<%= s.progress %>" min="0" max="100" style="width:60px;">
                                <button type="submit" class="btn btn-sm btn-warning">Update</button>
                            </form>
                            <form action="/admin/delete" method="POST" style="display:inline;">
                                <input type="hidden" name="id" value="<%= s.id %>">
                                <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Delete shipment?')">Delete</button>
                            </form>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
        <a href="/admin" class="btn btn-secondary">Refresh</a>
    </div>
</body>
</html>
