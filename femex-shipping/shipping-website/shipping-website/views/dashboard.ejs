<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - ChicagoShip</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <div class="container mt-5">
        <h2>User Dashboard</h2>
        <h4>Your Shipments History</h4>
        <table class="table table-striped">
            <thead><tr><th>ID</th><th>Status</th><th>Progress</th><th>Actions</th></tr></thead>
            <tbody>
                <% shipments.forEach(shipment => { %>
                    <tr>
                        <td><%= shipment.id %></td>
                        <td><%= shipment.status %></td>
                        <td><div class="progress"><div class="progress-bar" style="width: <%= shipment.progress %>%"></div></div></td>
                        <td><a href="/track" class="btn btn-sm btn-info">Track</a></td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
        <a href="/book" class="btn btn-primary">Book New Shipment</a>
    </div>
</body>
</html>
