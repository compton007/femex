<!DOCTYPE html>
<html>
<head><title>Reports - Femex</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="container mt-5">
<h2>Shipping Reports</h2>
<p>Total Shipments: <%= shipments.length %></p>
<!-- Add charts with Chart.js in production -->
<table class="table"><thead><tr><th>ID</th><th>Status</th></tr></thead>
<% shipments.forEach(s => { %><tr><td><%= s.id %></td><td><%= s.status %></td></tr><% }) %>
</table>
</body>
</html>
